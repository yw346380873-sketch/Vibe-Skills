{
  "version": 1,
  "updated": "2026-03-29",
  "backend_root_env": "VIBE_MEMORY_BACKEND_ROOT",
  "driver": {
    "command": "${VGO_PYTHON}",
    "script_path": "scripts/runtime/memory_backend_driver.py",
    "transport": "payload_file"
  },
  "lanes": {
    "serena": {
      "default_enabled": true,
      "disable_env": "VIBE_DISABLE_SERENA_BACKEND",
      "store_relpath": ".serena/project-decisions.jsonl",
      "project_key_env": [
        "VIBE_SERENA_PROJECT_KEY",
        "SERENA_PROJECT_KEY"
      ],
      "project_key_fallback": "none"
    },
    "ruflo": {
      "default_enabled": true,
      "disable_env": "VIBE_DISABLE_RUFLO_BACKEND",
      "store_relpath": ".tmp/ruflo/cards.jsonl",
      "project_key_env": [
        "VIBE_RUFLO_PROJECT_KEY",
        "VIBE_MEMORY_PROJECT_KEY"
      ],
      "project_key_fallback": "repo_slug"
    },
    "cognee": {
      "default_enabled": true,
      "disable_env": "VIBE_DISABLE_COGNEE_BACKEND",
      "store_relpath": ".tmp/cognee/graph.jsonl",
      "project_key_env": [
        "VIBE_COGNEE_PROJECT_KEY",
        "VIBE_MEMORY_PROJECT_KEY"
      ],
      "project_key_fallback": "repo_slug"
    }
  }
}
