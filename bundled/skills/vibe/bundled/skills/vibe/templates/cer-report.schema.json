{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vco.local/schemas/cer-report.schema.json",
  "title": "Context Evidence Report (CER)",
  "type": "object",
  "required": [
    "schema_version",
    "report_id",
    "date",
    "task",
    "trigger_signals",
    "findings",
    "actions",
    "comparison",
    "status"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "report_id": {
      "type": "string"
    },
    "date": {
      "type": "string"
    },
    "task": {
      "type": "object",
      "required": [
        "task_id",
        "topic",
        "grade",
        "task_type"
      ],
      "properties": {
        "task_id": {
          "type": "string"
        },
        "topic": {
          "type": "string"
        },
        "grade": {
          "type": "string",
          "enum": [
            "M",
            "L",
            "XL"
          ]
        },
        "task_type": {
          "type": "string",
          "enum": [
            "planning",
            "coding",
            "review",
            "debug",
            "research",
            "retro"
          ]
        }
      }
    },
    "trigger_signals": {
      "type": "object",
      "required": [
        "retry_count_10m",
        "fallback_rate",
        "context_pressure",
        "route_stability_pack",
        "route_stability_skill",
        "top1_top2_gap",
        "triggered_reasons"
      ],
      "properties": {
        "retry_count_10m": {
          "type": "number",
          "minimum": 0
        },
        "fallback_rate": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "context_pressure": {
          "type": "number",
          "minimum": 0
        },
        "route_stability_pack": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "route_stability_skill": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "top1_top2_gap": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "triggered_reasons": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "findings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "pattern",
          "pattern_label",
          "evidence",
          "root_cause",
          "intervention",
          "guardrail",
          "confidence"
        ],
        "properties": {
          "pattern": {
            "type": "string",
            "enum": [
              "CF-1",
              "CF-2",
              "CF-3",
              "CF-4",
              "CF-5",
              "CF-6"
            ]
          },
          "pattern_label": {
            "type": "string"
          },
          "evidence": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "root_cause": {
            "type": "string",
            "minLength": 1
          },
          "intervention": {
            "type": "string",
            "minLength": 1
          },
          "guardrail": {
            "type": "string",
            "minLength": 1
          },
          "confidence": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high"
            ]
          }
        }
      }
    },
    "actions": {
      "type": "object",
      "required": [
        "approved_actions",
        "deferred_actions",
        "owners",
        "due_dates"
      ],
      "properties": {
        "approved_actions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "deferred_actions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "owners": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "due_dates": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "comparison": {
      "type": "object",
      "required": [
        "baseline_report_id",
        "pattern_delta",
        "fallback_rate_delta",
        "stability_delta",
        "notes"
      ],
      "properties": {
        "baseline_report_id": {
          "type": "string"
        },
        "pattern_delta": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "fallback_rate_delta": {
          "type": "number"
        },
        "stability_delta": {
          "type": "number"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "validated",
        "invalid"
      ]
    }
  }
}
