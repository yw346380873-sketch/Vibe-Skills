        "grades": [
            "L",
            "XL"
        ],
        "task_types": [
            "coding",
            "review"
        ]
    },
    "recommendations_by_group": {
        "naming": "Prefer intention-revealing names and avoid ambiguous abbreviations.",
        "function_design": "Split oversized functions; avoid flag arguments and keep argument count focused.",
        "class_design": "Enforce single-responsibility classes and extract orchestration logic from god objects.",
        "side_effects": "Isolate side effects and keep core logic pure where possible.",
        "duplication": "Consolidate duplicated branches behind shared abstractions.",
        "error_handling": "Use explicit exceptions with consistent error boundaries and messages.",
        "tests": "Add focused tests around refactored units before broad rewrites."
    },
    "fallback_behavior": {
        "on_missing_config": "bypass_overlay",
        "on_probe_failure": "continue_advisory"
    }
