  "safety": {
    "fallback_on_error": true,
    "require_candidate_in_top_k": true,
    "min_override_confidence": 0.75,
    "allow_confirm_escalation": true,
    "allow_route_override": false
  },
  "rollout": {
    "apply_in_modes": ["soft", "strict"],
    "max_live_apply_rate": 1.0
  }
}




