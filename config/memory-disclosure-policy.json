{
  "version": 1,
  "updated": "2026-04-10",
  "policy_id": "memory-disclosure-capsules-v1",
  "enabled": true,
  "mode": "capsule_progressive_disclosure",
  "control_plane_owner": "vco",
  "defaults": {
    "pack_type": "capsule_digest",
    "max_capsules": 4,
    "max_chars_per_capsule": 360
  },
  "stages": {
    "skeleton_check": {
      "level": "minimal",
      "max_capsules": 2
    },
    "deep_interview": {
      "level": "bounded_context",
      "max_capsules": 3
    },
    "requirement_doc": {
      "level": "decision_focused",
      "max_capsules": 3
    },
    "xl_plan": {
      "level": "decision_and_relation_focused",
      "max_capsules": 4
    },
    "plan_execute": {
      "level": "execution_relevant",
      "max_capsules": 4
    },
    "phase_cleanup": {
      "level": "closure",
      "max_capsules": 2
    }
  },
  "invariants": {
    "forbid_raw_history_dump": true,
    "forbid_unbounded_disclosure": true,
    "preserve_owner_attribution": true
  }
}
